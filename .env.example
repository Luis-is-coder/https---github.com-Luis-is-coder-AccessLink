# Server
PORT=3000
NODE_ENV=development
JWT_SECRET=change-this-to-a-long-random-string

# PostgreSQL (required)
# Local example:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/accesslink
# Supabase example:
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres
DATABASE_URL=

# Email (optional – for emergency alerts & notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=AccessLink <noreply@accesslink.app>

# Twilio SMS (optional – for emergency alerts)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# App URL (used in email links)
APP_URL=http://localhost:3000

# ── Singapore Data Import (database/import-singapore.js) ──────────────────
# LTA DataMall — bus stops + MRT stations
# Register free at: https://datamall.lta.gov.sg/content/datamall/en/request-for-api.html
LTA_API_KEY=

# OpenRouteService — wheelchair routing
# Free tier at: https://openrouteservice.org/dev/#/signup
ORS_API_KEY=

# OneMap Singapore — public transit routing (Bus/MRT step-by-step)
# Register free at: https://www.onemap.gov.sg/apidocs/
ONEMAP_TOKEN=
